# dbrestore secrets — copy to /etc/dbrestore/dbrestore.env and `chmod 600`.
# These are injected into the container; dbrestore.yaml references them as ${VAR}
# and the CLI reads DBRESTORE_PASSPHRASE directly.

# --- Database credentials (match the ${...} placeholders in dbrestore.yaml) ---
PGPASSWORD=change-me
# MYSQL_PWD=change-me
# MONGODB_PASSWORD=change-me

# --- Backup encryption (AES-256-GCM). Optional but recommended. ---
DBRESTORE_PASSPHRASE=change-me-to-a-long-random-passphrase

# --- Offsite S3-compatible storage (optional; free tiers: Cloudflare R2, Backblaze B2) ---
# Reference these from the storage block in dbrestore.yaml via ${...}.
# AWS_ACCESS_KEY_ID=change-me
# AWS_SECRET_ACCESS_KEY=change-me

# --- Failure alerting via healthchecks.io (optional, free) ---
# Project "Ping key" from healthchecks.io. The units auto-create one check per
# profile (dbrestore-<profile>) and alert you if a scheduled backup stops pinging.
# HC_PING_KEY=change-me

# --- Offsite sync with rclone (optional; used by dbrestore-offsite@.timer) ---
# rclone builds its "offsite:" remote entirely from these env vars.
# OFFSITE_BUCKET=my-dbrestore-bucket
# RCLONE_CONFIG_OFFSITE_TYPE=s3
# RCLONE_CONFIG_OFFSITE_PROVIDER=Cloudflare
# RCLONE_CONFIG_OFFSITE_ACCESS_KEY_ID=change-me
# RCLONE_CONFIG_OFFSITE_SECRET_ACCESS_KEY=change-me
# RCLONE_CONFIG_OFFSITE_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
